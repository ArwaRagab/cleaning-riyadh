RewriteEngine On

# =========================
# 1. تحويل إلى HTTPS
# =========================
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# =========================
# 2. إزالة www
# =========================
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# =========================
# 3. إزالة index.html من الرابط
# =========================
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+(.*/)index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+index\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# =========================
# 4. منع استعراض الملفات
# =========================
Options -Indexes

# =========================
# 5. منع الـ Hotlinking (سرقة الصور)
# =========================
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https://(www\.)?cleaning-riyadh.online [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?google\.com [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?facebook\.com [NC]
RewriteCond %{HTTP_REFERER} !^https://(www\.)?t\.co [NC]
RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,L]

# =========================
# 6. ضغط Gzip
# =========================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# =========================
# 7. كاش لتحسين السرعة
# =========================
<IfModule mod_expires.c>
    ExpiresActive On

    # صور
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif  "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS & JS
    ExpiresByType text/css                     "access plus 1 month"
    ExpiresByType application/javascript       "access plus 1 month"
    ExpiresByType text/javascript              "access plus 1 month"

    # خطوط
    ExpiresByType font/woff                    "access plus 1 year"
    ExpiresByType font/woff2                   "access plus 1 year"
    ExpiresByType application/font-woff        "access plus 1 year"
    ExpiresByType application/font-woff2       "access plus 1 year"

    # HTML
    ExpiresByType text/html                    "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
    # Cache-Control للصور
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>

    # Cache-Control لـ CSS & JS
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>

    # Cache-Control للخطوط
    <FilesMatch "\.(woff|woff2)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
</IfModule>

# =========================
# 8. حماية الهيدرز الأمنية
# =========================
<IfModule mod_headers.c>
    # منع MIME sniffing
    Header set X-Content-Type-Options "nosniff"

    # منع Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # حماية XSS قديمة (للمتصفحات القديمة)
    Header set X-XSS-Protection "1; mode=block"

    # HSTS — إجبار HTTPS في المتصفح
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # Content Security Policy — عدّل على حسب موقعك
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; frame-ancestors 'self'"
</IfModule>

# =========================
# 9. حماية ملفات حساسة
# =========================
<FilesMatch "(\.env|\.git|\.gitignore|composer\.json|composer\.lock|package\.json|package-lock\.json|yarn\.lock|config\.php|wp-config\.php|\.htpasswd)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# حماية ملف .htaccess نفسه
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# =========================
# 10. منع تنفيذ PHP في مجلد الـ uploads
# =========================
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.(php|php5|phtml|phar)$ - [F,L]
</IfModule>
